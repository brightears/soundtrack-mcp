# Soundtrack Your Brand API Credentials
# Get your API token from: https://www.soundtrackyourbrand.com/our-api/apply
# The token should be base64-encoded (format: base64(client_id:client_secret))
SOUNDTRACK_API_TOKEN=your_base64_encoded_token_here

# Individual credentials (for reference)
SOUNDTRACK_CLIENT_ID=your_client_id_here
SOUNDTRACK_CLIENT_SECRET=your_client_secret_here

# Soundtrack API endpoint
SOUNDTRACK_API_URL=https://api.soundtrackyourbrand.com/v2

# Operator token — gates admin tools on the hosted server.
# When set: /operator/mcp and /mcp require the X-Operator-Token header
# to expose admin tools (subscription_activate, account_register, etc.).
# Clients connecting via /c/<account_ids>/mcp do NOT need this token but
# also can't access subscription_activate or account_register.
# Leave unset for self-hosted / single-user installs (defaults to operator).
OPERATOR_TOKEN=

# Scope aliases — JSON map of short alias → comma-separated account IDs.
# Lets customers with large portfolios connect via /c/<alias>/mcp instead
# of a multi-KB URL with raw IDs. Example:
#   SCOPE_ALIASES={"tui":"QWNjb3VudCwsMW5...,QWNjb3VudCwsMXR..."}
# When unset, /c/<segment>/mcp treats the segment as raw IDs (backwards-compat).
SCOPE_ALIASES=
